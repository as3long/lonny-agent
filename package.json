{
  "name": "lonny-agent",
  "version": "0.1.0",
  "description": "Per-call optimized coding agent with two-phase batch editing",
  "type": "module",
  "bin": {
    "lonny": "./.bin/cli.cjs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --experimental-ffi --allow-ffi --import tsx/esm src/index.ts",
    "start": "node --experimental-ffi --allow-ffi dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@earendil-works/pi-tui": "^0.75.5",
    "commander": "^12.0.0",
    "openai": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
