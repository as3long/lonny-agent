{
  "name": "lonny-agent",
  "version": "0.2.7",
  "license": "MIT",
  "repository": "github:as3long/lonny-agent",
  "description": "AI coding agent that does more with fewer API calls, optimized for Coding Plan (5h 1200-call bundle)",
  "type": "module",
  "bin": {
    "lonny": "./dist/index.js"
  },
  "scripts": {
    "copy:ast": "node scripts/copy-ast-wasm.mjs",
    "build": "npm run copy:ast && npm run build:js && npm run copy:web",
    "build:js": "esbuild src/index.ts --outdir=dist --platform=node --format=esm --target=node26 --packages=external --outbase=src",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "copy:web": "node scripts/copy-web.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:lines": "node scripts/check-line-count.mjs",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "biome check --fix --no-errors-on-unmatched"
    ],
    "*.{json,jsonc}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@vue-tui/runtime": "^0.1.0",
    "adm-zip": "^0.5.17",
    "commander": "^12.0.0",
    "get-east-asian-width": "1.6.0",
    "jest-diff": "^30.4.1",
    "marked": "15.0.12",
    "openai": "^4.0.0",
    "vue": "^3.5.38",
    "web-tree-sitter": "^0.26.9",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.19.19",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
