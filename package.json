{
  "name": "lonny-agent",
  "version": "0.2.6",
  "license": "MIT",
  "repository": "github:as3long/lonny-agent",
  "description": "AI coding agent that does more with fewer API calls, optimized for Coding Plan (5h 1200-call bundle)",
  "type": "module",
  "bin": {
    "lonny": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run copy:web && npm run copy:native",
    "copy:web": "node scripts/copy-web.mjs",
    "copy:native": "node scripts/copy-native.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "biome check --fix --no-errors-on-unmatched"
    ],
    "*.{json,jsonc}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "adm-zip": "^0.5.17",
    "commander": "^12.0.0",
    "get-east-asian-width": "1.6.0",
    "jest-diff": "^30.4.1",
    "marked": "15.0.12",
    "openai": "^4.0.0",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.19.19",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
